{
  "manifest_version": 3,
  "name": "SF Record Linker",
  "version": "1.4.1",
  "default_locale": "ja",
  "description": "__MSG_manifest_description__",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {},
  "background": {
    "service_worker": "background.js"
  },
  "permissions": [
    "clipboardWrite",
    "storage",
    "declarativeContent"
  ],
  "options_page": "options.html",
  "content_scripts": [
    {
      "matches": ["*://*.lightning.force.com/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}
