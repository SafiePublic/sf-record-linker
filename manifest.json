{
  "manifest_version": 3,
  "name": "SF Record Linker",
  "version": "1.0.0",
  "description": "Salesforce Lightning レコードページのリンクをワンクリックでコピー",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "permissions": [
    "clipboardWrite",
    "storage"
  ],
  "content_scripts": [
    {
      "matches": ["*://*.lightning.force.com/*"],
      "js": ["lib/link-formatter.js", "content.js"],
      "run_at": "document_idle"
    }
  ]
}
